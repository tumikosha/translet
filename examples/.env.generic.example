# Универсальный шаблон для simple_from_env.py.
# Скопируй в examples/.env и оставь только нужные строки под свой провайдер.

# === LLM ===
# provider: openai | azure | groq | nvidia
TRANSLET_LLM_PROVIDER=nvidia
TRANSLET_LLM_MODEL=meta/llama-3.1-70b-instruct
# TRANSLET_LLM_BASE_URL=https://...        # опционально, override базового URL

# Ключ можно задать одним из двух способов:
#   1. Provider-specific (рекомендуется — совпадает с конвенцией SDK):
#      OPENAI_API_KEY=sk-...
#      GROQ_API_KEY=gsk_...
NVIDIA_API_KEY=nvapi-REPLACE_ME
#      AZURE_OPENAI_API_KEY=...
#   2. Универсальный fallback (если provider-specific не задан):
# TRANSLET_API_KEY=...
#
# Только для Azure:
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-06-01

# === Хранилище правил (dbset) ===
TRANSLET_DB_PATH=sqlite:///examples/translet_example.db
TRANSLET_DB_TABLE=translet_rules

# === Поведение пайплайна ===
# TRANSLET_TTL_SECONDS=86400
TRANSLET_MAX_RETRIES=2
